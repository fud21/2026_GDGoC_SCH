# Spring Boot datasource environment variables.
# Copy this file to .env only for local reference if needed.
# Spring Boot does not automatically load .env files; set these values in
# IntelliJ Run Configuration environment variables or export them in the shell.

DB_URL=jdbc:mysql://localhost:3306/stockmanager?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=stockuser
DB_PASSWORD=stockpass
