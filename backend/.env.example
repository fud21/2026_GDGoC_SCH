PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=gdgoc_sch

# JWT 서명 키 — 배포 시 반드시 무작위 값으로 교체
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Google AI Studio에서 발급 (무료 티어)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# AI 피드백은 선택 기능입니다. 점수는 항상 서버의 고정 루브릭으로 계산합니다.
AI_FEEDBACK_ENABLED=false
LLM_PROVIDER=gemini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# 쉼표로 구분한 허용 프론트엔드 주소
CORS_ORIGINS=http://localhost:5173
